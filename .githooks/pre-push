#!/usr/bin/env bash
#
# pre-push hook: auto-increment patch version in version.ts
# Skips if version was already bumped in the current commit.
#

set -euo pipefail

VERSION_FILE="packages/node/src/version.ts"

if [ ! -f "$VERSION_FILE" ]; then
	exit 0
fi

# Read current version
CURRENT=$(grep -oP '"\K[0-9]+\.[0-9]+\.[0-9]+' "$VERSION_FILE" 2>/dev/null || echo "")
if [ -z "$CURRENT" ]; then
	exit 0
fi

# Check if version.ts was already modified in the most recent commit
ALREADY_BUMPED=$(git diff HEAD~1 HEAD --name-only 2>/dev/null | grep -c "$VERSION_FILE" || true)
if [ "$ALREADY_BUMPED" -gt 0 ]; then
	# Version file was already changed in this commit, skip auto-bump
	exit 0
fi

# Increment patch: 0.3.0 -> 0.3.1
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

# Write new version
sed -i '' "s/\"$CURRENT\"/\"$NEW_VERSION\"/" "$VERSION_FILE"

# Also update package.json
PKG_FILE="packages/node/package.json"
if [ -f "$PKG_FILE" ]; then
	sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PKG_FILE"
	git add "$PKG_FILE"
fi

# Also update API version endpoint
API_FILE="packages/api/start.ts"
if [ -f "$API_FILE" ]; then
	sed -i '' "s/version: \"$CURRENT\"/version: \"$NEW_VERSION\"/g" "$API_FILE"
	git add "$API_FILE"
fi

git add "$VERSION_FILE"
git commit --amend --no-edit --no-verify

echo "[pre-push] Version bumped: $CURRENT -> $NEW_VERSION"
