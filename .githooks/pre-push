#!/usr/bin/env bash
#
# pre-push hook: auto-bump version, never block for version reasons.
# Only test failures block a push.
#

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERSION_FILE="packages/node/src/version.ts"

cd "$REPO_DIR"

# Auto-increment patch version (if not already bumped in this commit)
if [ -f "$VERSION_FILE" ]; then
	CURRENT=$(grep -o '"[0-9]*\.[0-9]*\.[0-9]*"' "$VERSION_FILE" 2>/dev/null | tr -d '"' || echo "")
	if [ -n "$CURRENT" ]; then
		ALREADY_BUMPED=$(git diff HEAD~1 HEAD --name-only 2>/dev/null | grep -c "$VERSION_FILE" || true)
		if [ "$ALREADY_BUMPED" -eq 0 ]; then
			MAJOR=$(echo "$CURRENT" | cut -d. -f1)
			MINOR=$(echo "$CURRENT" | cut -d. -f2)
			PATCH=$(echo "$CURRENT" | cut -d. -f3)
			NEW_PATCH=$((PATCH + 1))
			NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

			sed -i '' "s/\"$CURRENT\"/\"$NEW_VERSION\"/" "$VERSION_FILE"
			git add "$VERSION_FILE"

			PKG_FILE="packages/node/package.json"
			if [ -f "$PKG_FILE" ]; then
				sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PKG_FILE"
				git add "$PKG_FILE"
			fi

			API_FILE="packages/api/start.ts"
			if [ -f "$API_FILE" ]; then
				sed -i '' "s/version: \"$CURRENT\"/version: \"$NEW_VERSION\"/g" "$API_FILE"
				git add "$API_FILE"
			fi

			git commit --amend --no-edit --no-verify
			echo "[pre-push] Version bumped: $CURRENT -> $NEW_VERSION"
		fi
	fi
fi

exit 0
