#!/usr/bin/env bash
#
# pre-push hook: run pre-deploy safety checks and auto-increment version.
# Bypass with: git push --no-verify
#

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
VERSION_FILE="packages/node/src/version.ts"

cd "$REPO_DIR"

# 1. Run pre-deploy safety checks (if script exists)
if [ -f "scripts/pre-deploy.sh" ]; then
	echo "[pre-push] Running pre-deploy safety checks..."
	if ! bash scripts/pre-deploy.sh; then
		echo ""
		echo "[pre-push] BLOCKED: pre-deploy checks failed."
		echo "[pre-push] Fix the issues above or use --no-verify to bypass (not recommended)."
		exit 1
	fi
fi

# 2. Auto-increment patch version (if not already bumped)
if [ ! -f "$VERSION_FILE" ]; then
	exit 0
fi

CURRENT=$(grep -o '"[0-9]*\.[0-9]*\.[0-9]*"' "$VERSION_FILE" 2>/dev/null | tr -d '"' || echo "")
if [ -z "$CURRENT" ]; then
	exit 0
fi

# Check if version.ts was already modified in the most recent commit
ALREADY_BUMPED=$(git diff HEAD~1 HEAD --name-only 2>/dev/null | grep -c "$VERSION_FILE" || true)
if [ "$ALREADY_BUMPED" -gt 0 ]; then
	exit 0
fi

# Increment patch
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"

sed -i '' "s/\"$CURRENT\"/\"$NEW_VERSION\"/" "$VERSION_FILE"

PKG_FILE="packages/node/package.json"
if [ -f "$PKG_FILE" ]; then
	sed -i '' "s/\"version\": \"$CURRENT\"/\"version\": \"$NEW_VERSION\"/" "$PKG_FILE"
	git add "$PKG_FILE"
fi

API_FILE="packages/api/start.ts"
if [ -f "$API_FILE" ]; then
	sed -i '' "s/version: \"$CURRENT\"/version: \"$NEW_VERSION\"/g" "$API_FILE"
	git add "$API_FILE"
fi

git add "$VERSION_FILE"
git commit --amend --no-edit --no-verify

echo "[pre-push] Version bumped: $CURRENT -> $NEW_VERSION"
