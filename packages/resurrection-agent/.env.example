# Required: LLM topic learning + tweet generation via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: defaults to openai/gpt-4o-mini
LLM_MODEL=openai/gpt-4o-mini

# Optional: defaults to https://api.ensoul.dev
ENSOUL_API_URL=https://api.ensoul.dev

# Optional: defaults to https://explorer.ensoul.dev
ENSOUL_EXPLORER=https://explorer.ensoul.dev

# Optional: X (Twitter) credentials. If set, agent posts to X.
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...

# Optional: Bluesky credentials. If set, agent posts to Bluesky.
# Create an app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# At least one of (X creds, Bluesky creds) is required for posting.
# Without either, the agent runs in monitor-only mode (logs to file).
