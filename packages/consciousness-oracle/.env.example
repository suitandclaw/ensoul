# Required: LLM analysis via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: defaults to openai/gpt-4o-mini
LLM_MODEL=openai/gpt-4o-mini

# Optional: GitHub token raises the search rate limit from 10/min to 30/min
GITHUB_TOKEN=ghp_...

# Optional: X (Twitter) credentials. If set, oracle posts to X.
X_API_KEY=...
X_API_SECRET=...
X_ACCESS_TOKEN=...
X_ACCESS_SECRET=...

# Optional: Bluesky credentials. If set, oracle posts to Bluesky.
# Create an app password at https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# At least one of (X creds, Bluesky creds) is required to post.
# Without either, the oracle runs in monitor-only mode (logs to file).
