# Required: Bluesky credentials for the @ensoul account
BLUESKY_HANDLE=ensoul.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# Optional but recommended: enables LLM stat-post wording variation
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: defaults to openai/gpt-4o-mini
LLM_MODEL=openai/gpt-4o-mini

# Optional: defaults to https://api.ensoul.dev
ENSOUL_API_URL=https://api.ensoul.dev
